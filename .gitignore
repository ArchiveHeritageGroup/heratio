# Local agent worktrees
.claude/worktrees/

# MCP server dependencies (each server's package.json is checked in,
# node_modules is rebuilt by `npm install` on deploy)
.claude/mcp-servers/*/node_modules/

# Playwright + test runner artefacts
test-results/
playwright-report/
/tests/e2e/reports/

# Generated exports / reports
/storage/app/exports/
/storage/app/reports/
*.bak
*.bak-*
*.bak.*
*.bak[0-9]*
.km-ingest-staging/

# MCP config — may contain API keys (KM_API_KEY etc.)
.mcp.json

# Agent CLI per-user settings — may contain commands invoking sshpass with literals
.claude/settings.local.json

# Agent CLI harness scheduled-task lock - transient runtime artefact
.claude/scheduled_tasks.lock

# SharePoint integration is LOCAL-only per the SP NO-PUSH policy. Canonical
# source lives at /opt/ahg-sp-integration/ on the integration host; the
# Heratio-side port in app/Domain/SharePoint/ must NEVER be committed.
/app/Domain/SharePoint/

# NLSA tender reference PDFs - keep in docs/ for reference, never commit (large binaries)
docs/READVERTISEMENT*.pdf

# Demo/source content photos - seed material only; the app serves from uploads/ + DAM
# at runtime, so these large binaries must never be committed (#triage 2026-06-05).
/docs/images/ai/
/docs/images/cars/
/docs/images/museum/
/docs/images/naval/
/docs/images/peace/
/docs/images/war/
/docs/images/Dr. Benson/
/UNILISA Calll for papers.jpg

# FS-Scotland indexer (heratio#1336): register scans + project brief are source
# material fed to the HTR indexer at runtime - never commit the binaries (194MB
# of JPEGs + the .docx brief). The fs-metadata-capture extension CODE stays tracked.
/fs-metadata-capture/images/
/fs-metadata-capture/*.docx

# heratio#1183 point-cloud host symlinks (provisioned by ahg:pointcloud-setup)
/public/pointclouds
/public/vendor/potree
/public/splats

# Scratch / working files (patches, debug scripts, audit dumps)
tmp/
.env.bak-*
.env.bak
