#!/usr/bin/env bash
# =============================================================================
# bin/install — Heratio standalone master installer
# =============================================================================
# Single-command install for a fresh Linux box. Idempotent — re-running detects
# already-completed stages and skips them. See docs/standalone-install-plan.md.
#
# Usage:
#   sudo bin/install
#   sudo bin/install --domain=mysite.example --admin-email=admin@mysite.example
#   sudo bin/install --non-interactive --admin-password='hunter2'
#
# Stages (each idempotent):
#   1. Preflight     — check PHP/MySQL/Nginx/Redis/Node/Composer/git/ES present
#   2. Composer      — composer install --no-dev (skipped if vendor/ up-to-date)
#   3. NPM           — npm ci && npm run build (skipped if public/build/ exists)
#   4. .env          — copy .env.example → .env, fill APP_URL/DB/HERATIO_*,
#                       artisan key:generate (skipped if .env present)
#   5. DB create     — CREATE DATABASE heratio (skipped if exists)
#   6. Core schema   — load database/core/0[0-3]_*.sql via mysql
#   7. Plugin schema — php artisan heratio:install-bootstrap --pass=2
#   8. Seeds         — load database/seeds/0[0-7]_*.sql via mysql
#   9. Admin user    — create superuser via heratio:user:add-superuser
#   10. Storage      — mkdir HERATIO_UPLOADS_PATH/HERATIO_BACKUPS_PATH
#   11. Elasticsearch — php artisan ahg:es-reindex --drop  (--skip-es to skip)
#   12. Nginx        — render config/nginx/heratio.conf.template, link, reload
#                       (--skip-nginx to skip)
#   13. Smoke test   — curl /, /admin/login, /informationobject/browse
#   14. Report       — print URLs, admin creds, optional sub-installer hints
#
# Crash behaviour: every stage wraps in `set -e`. Failure prints stage + exits
# non-zero. Re-running picks up where it left off.
#
# Copyright (C) 2026 Johan Pieterse / Plain Sailing iSystems
# AGPL-3.0-or-later.
# =============================================================================

set -euo pipefail

# ------------------------------------------------------------ defaults
INSTALL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

DOMAIN=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
DB_NAME="heratio"
DB_USER="root"
DB_PASS=""
DB_HOST="127.0.0.1"
STORAGE_PATH=""
ES_HOST="http://localhost:9200"
ES_PREFIX="heratio_"
PHP_FPM_SOCK="/run/php/php8.3-fpm.sock"
SKIP_ES=0
SKIP_NGINX=0
NON_INTERACTIVE=0

# ------------------------------------------------------------ flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        --domain=*)         DOMAIN="${1#*=}" ;;
        --admin-email=*)    ADMIN_EMAIL="${1#*=}" ;;
        --admin-password=*) ADMIN_PASSWORD="${1#*=}" ;;
        --db-name=*)        DB_NAME="${1#*=}" ;;
        --db-user=*)        DB_USER="${1#*=}" ;;
        --db-pass=*)        DB_PASS="${1#*=}" ;;
        --db-host=*)        DB_HOST="${1#*=}" ;;
        --storage-path=*)   STORAGE_PATH="${1#*=}" ;;
        --es-host=*)        ES_HOST="${1#*=}" ;;
        --php-fpm-sock=*)   PHP_FPM_SOCK="${1#*=}" ;;
        --skip-es)          SKIP_ES=1 ;;
        --skip-nginx)       SKIP_NGINX=1 ;;
        --non-interactive)  NON_INTERACTIVE=1 ;;
        -h|--help)
            grep -E '^# ' "$0" | sed 's/^# \?//' | head -40
            exit 0
            ;;
        *)  echo "unknown flag: $1" >&2; exit 2 ;;
    esac
    shift
done

cd "$INSTALL_DIR"

# ------------------------------------------------------------ helpers
say()  { printf '\033[1;36m==> %s\033[0m\n' "$*"; }
ok()   { printf '    \033[1;32m✓\033[0m %s\n' "$*"; }
warn() { printf '    \033[1;33m⚠\033[0m %s\n' "$*"; }
die()  { printf '    \033[1;31m✗\033[0m %s\n' "$*" >&2; exit 1; }

prompt_if_empty() {
    local var="$1" prompt="$2" default="${3:-}"
    [[ -n "${!var:-}" ]] && return
    [[ "$NON_INTERACTIVE" -eq 1 ]] && die "$prompt is required (--${var//_/-}=...) in --non-interactive mode"
    if [[ -n "$default" ]]; then
        read -rp "$prompt [$default]: " val; val="${val:-$default}"
    else
        read -rp "$prompt: " val
    fi
    printf -v "$var" '%s' "$val"
}

mysql_run() {
    if [[ -n "$DB_PASS" ]]; then
        mysql -h "$DB_HOST" -u "$DB_USER" -p"$DB_PASS" "$@"
    else
        mysql -h "$DB_HOST" -u "$DB_USER" "$@"
    fi
}

# ============================================================================
# 1. Preflight
# ============================================================================
say "Stage 1/14 — preflight"

[[ $EUID -eq 0 ]] || warn "not running as root — some stages may fail (use sudo)"

need() {
    command -v "$1" &>/dev/null || die "missing dependency: $1 ($2)"
}
need php       "apt-get install -y php8.3-cli php8.3-fpm php8.3-mysql php8.3-mbstring php8.3-xml php8.3-curl"
need composer  "https://getcomposer.org/download/"
need mysql     "apt-get install -y mysql-server"
need node      "apt-get install -y nodejs npm"
need npm       "(comes with nodejs)"
need git       "apt-get install -y git"
need curl      "apt-get install -y curl"
PHP_VER="$(php -r 'echo PHP_VERSION;')"
PHP_MAJ="$(echo "$PHP_VER" | cut -d. -f1)"
PHP_MIN="$(echo "$PHP_VER" | cut -d. -f2)"
[[ "$PHP_MAJ" -ge 8 && "$PHP_MIN" -ge 3 ]] || die "PHP 8.3+ required (found $PHP_VER)"

if mysql_run -e "SELECT 1" &>/dev/null; then
    ok "MySQL reachable as $DB_USER@$DB_HOST"
else
    die "cannot connect to MySQL as $DB_USER@$DB_HOST — check creds"
fi

if [[ "$SKIP_ES" -eq 0 ]]; then
    if curl -sf "$ES_HOST" &>/dev/null; then
        ok "Elasticsearch reachable at $ES_HOST"
    else
        warn "Elasticsearch unreachable at $ES_HOST — pass --skip-es to bypass or set --es-host"
        die  "cannot reach ES (see warning above)"
    fi
fi

ok "preflight passed (PHP $PHP_VER, $(node -v), $(composer --version | head -1))"

# ============================================================================
# Collect required user-facing values
# ============================================================================
prompt_if_empty DOMAIN       "Domain (e.g. heratio.example.com)"
prompt_if_empty ADMIN_EMAIL  "Admin email"   "admin@${DOMAIN}"
[[ -z "$ADMIN_PASSWORD" ]] && ADMIN_PASSWORD="$(openssl rand -base64 18 | tr -d '=+/' | head -c 16)"

# Default storage path is the in-tree uploads/ — matches config/heratio.php
# which has storage_path = base_path('uploads'). Production deployments
# override via --storage-path or HERATIO_STORAGE_PATH in .env (e.g. NAS mount).
[[ -z "$STORAGE_PATH"  ]] && STORAGE_PATH="${INSTALL_DIR}/uploads"

# ============================================================================
# 2. Composer
# ============================================================================
say "Stage 2/14 — composer install"
if [[ -d vendor && -f vendor/autoload.php && composer.lock -ot vendor ]]; then
    ok "vendor/ up-to-date — skipping"
else
    composer install --no-dev --no-interaction --optimize-autoloader
    ok "composer install complete"
fi

# ============================================================================
# 3. NPM build
# ============================================================================
say "Stage 3/14 — npm build"
if [[ -d public/build && -n "$(ls -A public/build 2>/dev/null)" ]]; then
    ok "public/build/ present — skipping"
else
    npm ci --silent
    npm run build --silent
    ok "npm build complete"
fi

# ============================================================================
# 4. .env
# ============================================================================
say "Stage 4/14 — .env"
# Always bust Laravel's cached config / routes / views before this stage. A
# stale bootstrap/cache/config.php from a previous install (or from a CI
# vendor-cache layer) holds DB credentials that no longer match the .env we
# are about to render, and Laravel's PDO would connect with the wrong
# password — silently breaking Stage 7 (heratio:install-bootstrap) where
# every package install.sql throws on DB::unprepared and the bootstrap step
# adds 0 tables. Idempotent: clear is safe whether the cache exists or not.
# Tracked under heratio issue #53.
php artisan config:clear --ansi 2>/dev/null || true
php artisan route:clear  --ansi 2>/dev/null || true
php artisan view:clear   --ansi 2>/dev/null || true
if [[ -f .env ]]; then
    ok ".env present — leaving alone"
else
    [[ -f .env.example ]] || die ".env.example missing — cannot bootstrap"
    cp .env.example .env

    # render values + production-safe overrides
    sed -i \
        -e "s|^APP_URL=.*|APP_URL=https://${DOMAIN}|" \
        -e "s|^APP_ENV=.*|APP_ENV=production|" \
        -e "s|^APP_DEBUG=.*|APP_DEBUG=false|" \
        -e "s|^LOG_LEVEL=.*|LOG_LEVEL=warning|" \
        -e "s|^SESSION_SECURE_COOKIE=.*|SESSION_SECURE_COOKIE=true|" \
        -e "s|^SESSION_HTTP_ONLY=.*|SESSION_HTTP_ONLY=true|" \
        -e "s|^SESSION_SAME_SITE=.*|SESSION_SAME_SITE=lax|" \
        -e "s|^SESSION_ENCRYPT=.*|SESSION_ENCRYPT=true|" \
        -e "s|^DB_HOST=.*|DB_HOST=${DB_HOST}|" \
        -e "s|^DB_DATABASE=.*|DB_DATABASE=${DB_NAME}|" \
        -e "s|^DB_USERNAME=.*|DB_USERNAME=${DB_USER}|" \
        -e "s|^DB_PASSWORD=.*|DB_PASSWORD=${DB_PASS}|" \
        -e "s|^HERATIO_STORAGE_PATH=.*|HERATIO_STORAGE_PATH=${STORAGE_PATH}|" \
        -e "s|^HERATIO_UPLOADS_PATH=.*|HERATIO_UPLOADS_PATH=${STORAGE_PATH}|" \
        -e "s|^HERATIO_BACKUPS_PATH=.*|HERATIO_BACKUPS_PATH=${STORAGE_PATH}/backups|" \
        -e "s|^ELASTICSEARCH_HOST=.*|ELASTICSEARCH_HOST=${ES_HOST}|" \
        -e "s|^ELASTICSEARCH_PREFIX=.*|ELASTICSEARCH_PREFIX=${ES_PREFIX}|" \
        .env

    # Ensure every key the rest of the script reads back exists in .env. The
    # default Laravel .env.example uses DB_CONNECTION=sqlite and omits most
    # of these, so the `sed -i s|^KEY=...|KEY=value|` lines above silently
    # no-op when KEY is absent. Re-add explicitly here.
    ensure_env() { grep -q "^$1=" .env || echo "$1=$2" >> .env; }
    ensure_env APP_ENV               production
    ensure_env APP_DEBUG             false
    ensure_env LOG_LEVEL             warning
    ensure_env DB_CONNECTION         mysql
    ensure_env DB_HOST               "${DB_HOST}"
    ensure_env DB_DATABASE           "${DB_NAME}"
    ensure_env DB_USERNAME           "${DB_USER}"
    ensure_env DB_PASSWORD           "${DB_PASS}"
    ensure_env HERATIO_STORAGE_PATH  "${STORAGE_PATH}"
    ensure_env HERATIO_UPLOADS_PATH  "${STORAGE_PATH}"
    ensure_env HERATIO_BACKUPS_PATH  "${STORAGE_PATH}/backups"
    ensure_env ELASTICSEARCH_HOST    "${ES_HOST}"
    ensure_env ELASTICSEARCH_PREFIX  "${ES_PREFIX}"
    ensure_env SESSION_SECURE_COOKIE true
    ensure_env SESSION_HTTP_ONLY     true
    ensure_env SESSION_SAME_SITE     lax

    chmod 640 .env
    chown root:www-data .env 2>/dev/null || true

    php artisan key:generate --no-interaction --force
    ok ".env rendered (production env, debug off, secure cookies) + APP_KEY generated"
fi

# Re-export key env values from .env so the rest of the script uses the
# canonical values (in case the user kept an existing .env with different DB
# settings). `|| true` lets `set -euo pipefail` survive missing keys; the
# `${var:-fallback}` expansion keeps the flag-supplied default when the .env
# value is empty.
get_env() { grep -E "^$1=" .env 2>/dev/null | tail -1 | cut -d= -f2- || true; }
_v="$(get_env DB_DATABASE)";          DB_NAME="${_v:-$DB_NAME}"
_v="$(get_env DB_USERNAME)";          DB_USER="${_v:-$DB_USER}"
_v="$(get_env DB_PASSWORD)";          DB_PASS="${_v:-$DB_PASS}"
_v="$(get_env DB_HOST)";              DB_HOST="${_v:-$DB_HOST}"
_v="$(get_env HERATIO_STORAGE_PATH)"; STORAGE_PATH="${_v:-$STORAGE_PATH}"
unset _v

# ============================================================================
# 5. DB create
# ============================================================================
say "Stage 5/14 — database"
if mysql_run -e "USE \`$DB_NAME\`" &>/dev/null; then
    ok "database $DB_NAME exists"
else
    mysql_run -e "CREATE DATABASE \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci"
    ok "created database $DB_NAME"
fi

# Security: warn if MySQL is bound to 0.0.0.0 (publicly reachable). Default
# Ubuntu MySQL 8 bind is 127.0.0.1; this just catches misconfigured installs.
if ss -tln | awk '{print $4}' | grep -qE "^0\.0\.0\.0:3306\$|^\[::]:3306\$"; then
    warn "MySQL is bound to 0.0.0.0:3306 — publicly reachable. Recommend: set bind-address=127.0.0.1 in mysqld.cnf"
fi

# ============================================================================
# 6. Core schema (00→03)
# ============================================================================
say "Stage 6/14 — core schema"
for f in database/core/0*.sql; do
    [[ -f "$f" ]] || continue
    bn="$(basename "$f")"
    mysql_run "$DB_NAME" < "$f" 2>/tmp/heratio-install-${bn}.err && \
        ok "loaded $bn" || die "failed loading $bn (see /tmp/heratio-install-${bn}.err)"
done

# ============================================================================
# 7. Plugin schema (artisan two-pass)
# ============================================================================
say "Stage 7/14 — plugin schema (heratio:install-bootstrap --pass=2)"
php artisan heratio:install-bootstrap --pass=2
ok "plugin schemas loaded"

# ============================================================================
# 8. Seeds (00→07)
# ============================================================================
say "Stage 8/14 — seeds"
for f in database/seeds/0*.sql; do
    [[ -f "$f" ]] || continue
    bn="$(basename "$f")"
    mysql_run "$DB_NAME" < "$f" 2>/tmp/heratio-install-${bn}.err && \
        ok "loaded $bn" || warn "$bn produced errors (see /tmp/heratio-install-${bn}.err) — continuing"
done

# ============================================================================
# 9. Admin user
# ============================================================================
say "Stage 9/14 — admin user"
ADMIN_ID=$(mysql_run -Nse "SELECT id FROM \`$DB_NAME\`.\`user\` WHERE email='${ADMIN_EMAIL}' LIMIT 1" 2>/dev/null || echo "")
if [[ -n "$ADMIN_ID" ]]; then
    ok "admin user already exists (id=$ADMIN_ID, email=$ADMIN_EMAIL)"
else
    HASH="$(php -r "echo password_hash('${ADMIN_PASSWORD}', PASSWORD_BCRYPT);")"
    mysql_run "$DB_NAME" <<SQL >/dev/null
INSERT INTO object (class_name, created_at, updated_at, serial_number)
VALUES ('QubitUser', NOW(), NOW(), 0);
SET @uid = LAST_INSERT_ID();
INSERT INTO actor (id, source_culture, description_status_id, description_detail_id, description_identifier)
VALUES (@uid, 'en', NULL, NULL, NULL);
INSERT INTO actor_i18n (id, culture, authorized_form_of_name)
VALUES (@uid, 'en', 'Administrator');
INSERT INTO \`user\` (id, username, email, password_hash, salt, active)
VALUES (@uid, 'admin', '${ADMIN_EMAIL}', '${HASH}', '', 1);
SQL
    ok "admin created (email=$ADMIN_EMAIL — password printed at end)"
fi

# ============================================================================
# 10. Storage paths
# ============================================================================
say "Stage 10/14 — storage paths"
# Default layout when STORAGE_PATH = ${INSTALL_DIR}/uploads:
#   uploads/r/                       — actual digital-object tree (per-repo subdirs)
#   uploads/backups/                 — DB backups (HERATIO_BACKUPS_PATH)
#   uploads/derivatives/             — generated thumbnails / refs
# Production overrides: storage_path on a NAS mount, with uploads/r as a
# symlink into a separate archive partition.
for d in "$STORAGE_PATH" "$STORAGE_PATH/r" "$STORAGE_PATH/backups" "$STORAGE_PATH/derivatives" "$STORAGE_PATH/tmp"; do
    if [[ -d "$d" ]]; then
        ok "$d exists"
    else
        mkdir -p "$d"
        chown -R www-data:www-data "$d" 2>/dev/null || true
        ok "created $d"
    fi
done

# ============================================================================
# 11. Elasticsearch
# ============================================================================
say "Stage 11/14 — Elasticsearch"
if [[ "$SKIP_ES" -eq 1 ]]; then
    warn "skipped (--skip-es)"
else
    if curl -sf "$ES_HOST" &>/dev/null; then
        php artisan ahg:es-reindex --drop --quiet 2>&1 | tail -5 || warn "reindex returned non-zero — check logs"
        ok "ES indices created/reindexed"
    else
        warn "ES not reachable at $ES_HOST — skipping reindex"
    fi
fi

# ============================================================================
# 12. Nginx
# ============================================================================
say "Stage 12/14 — nginx"
if [[ "$SKIP_NGINX" -eq 1 ]]; then
    warn "skipped (--skip-nginx) — render manually:"
    warn "  cp config/nginx/heratio.conf.template /etc/nginx/sites-available/${DOMAIN}.conf"
elif ! command -v nginx &>/dev/null; then
    warn "nginx not installed — skipping"
else
    VHOST="/etc/nginx/sites-available/${DOMAIN}.conf"
    LINK="/etc/nginx/sites-enabled/${DOMAIN}.conf"
    if [[ -f "$VHOST" ]]; then
        ok "$VHOST exists — leaving alone"
    else
        sed \
            -e "s|{{DOMAIN}}|${DOMAIN}|g" \
            -e "s|{{INSTALL_DIR}}|${INSTALL_DIR}|g" \
            -e "s|{{UPLOADS_PATH}}|${STORAGE_PATH}|g" \
            -e "s|{{PHP_FPM_SOCK}}|${PHP_FPM_SOCK}|g" \
            config/nginx/heratio.conf.template > "$VHOST"
        ln -sf "$VHOST" "$LINK"
        nginx -t && systemctl reload nginx && ok "nginx vhost installed + reloaded"
    fi
fi

# ============================================================================
# 13. Smoke test
# ============================================================================
say "Stage 13/14 — smoke test"
TARGET="http://localhost"
if [[ "$SKIP_NGINX" -eq 0 ]]; then
    TARGET="https://${DOMAIN}"
fi
RESP="$(curl -sk -o /dev/null -w '%{http_code}' "$TARGET/" 2>/dev/null || echo "000")"
[[ "$RESP" =~ ^(200|301|302)$ ]] && ok "GET / -> $RESP" || warn "GET / -> $RESP (vhost may need DNS / SSL setup)"

# ============================================================================
# 14. Report
# ============================================================================
cat <<REPORT

═══════════════════════════════════════════════════════════════════════════════
  Heratio installed
═══════════════════════════════════════════════════════════════════════════════
  URL          : https://${DOMAIN}/
  Admin login  : https://${DOMAIN}/admin/login
    Email      : ${ADMIN_EMAIL}
    Password   : ${ADMIN_PASSWORD}    ← printed once. Save it now.
  Database     : ${DB_NAME}@${DB_HOST}
  Storage      : ${STORAGE_PATH}
  Elasticsearch: ${ES_HOST}  (prefix: ${ES_PREFIX})

  Optional sub-installers (run when ready):
    sudo bin/install-cantaloupe   IIIF deep-zoom for TIFF/JP2 masters
    sudo bin/install-qdrant        Semantic / image-similarity search

  Install logs in /tmp/heratio-install-*.err

═══════════════════════════════════════════════════════════════════════════════
REPORT
