[Unit]
Description=AHG HTR Service (Handwritten Text Recognition) - GPU
After=network.target

[Service]
Type=simple
User=johanpiet
WorkingDirectory=/opt/ahg-ai/htr
ExecStart=/opt/ahg-ai/htr/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 5006
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
