# Heratio production .env template.
# Copy to .env on the production host, then fill in real secrets.
# DO NOT commit a populated copy.

APP_NAME=Heratio
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-production-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — warning level, daily rotation, no debug noise in prod.
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — MySQL 8 (production). Never sqlite in prod.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heratio
DB_USERNAME=heratio
DB_PASSWORD=

# Sessions — encrypted, secure cookies, samesite=lax.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue — database-backed, run a worker via systemd / supervisor.
QUEUE_CONNECTION=database

# Cache — database-backed (no Redis dependency by default).
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — replace with real SMTP / SES / Mailgun config in prod.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@your-production-domain.example
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Heratio storage paths. NEVER hardcode in code — set them here.
HERATIO_STORAGE_PATH=/var/lib/heratio
HERATIO_UPLOADS_PATH=/var/lib/heratio/archive
HERATIO_BACKUPS_PATH=/var/lib/heratio/backups

# Elasticsearch — Heratio's own indices.
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_PREFIX=heratio_

# RiC — Fuseki Triplestore.
FUSEKI_URL=http://localhost:3030/ric
FUSEKI_USER=
FUSEKI_PASSWORD=

# RiC — Qdrant Vector Search.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=heratio_records

# RiC — Elasticsearch (separate from the AtoM-style indices above).
ELASTICSEARCH_URL=http://localhost:9200

# AI — Ollama endpoint. Lock to a private host in prod.
HERATIO_OLLAMA_URL=http://localhost:11434

# IIIF — Cantaloupe (deep zoom).
HERATIO_IIIF_URL=http://localhost:8182
