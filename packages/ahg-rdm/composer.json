{
    "name": "ahg/rdm",
    "description": "Heratio AHG RDM - sovereign research-data-management module (datasets, POPIA scan, FAIR deposit). Thin orchestration over ahg-ingest, ahg-research, ahg-ai-services, ahg-core.",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "require": {
        "ahg/core": "@dev",
        "ahg/ingest": "@dev",
        "ahg/research": "@dev",
        "ahg/information-object-manage": "@dev",
        "ahg/ai-services": "@dev",
        "ahg/pdf-tools": "@dev",
        "ahg/doi-manage": "@dev"
    },
    "autoload": {
        "psr-4": {
            "AhgRdm\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AhgRdm\\AhgRdmServiceProvider"
            ]
        }
    }
}
