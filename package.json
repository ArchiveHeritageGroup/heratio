{
  "$schema": "https://schemas.json-schema.org/draft-07/schema#",
  "name": "heratio",
  "description": "Heritage Archives Technology Platform - Laravel Migration from AtoM",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "concurrently --kill-others-on-fail \"npm run test:laravel\" \"npm run test:e2e\"",
    "test:laravel": "php artisan test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:discovery": "playwright test tests/e2e/00-discovery",
    "test:workflows": "playwright test tests/e2e/03-workflows",
    "test:parity": "playwright test tests/e2e/00-discovery/parity-scanner.spec.ts",
    "parity:report": "php artisan route:list --json > /tmp/routes.json && php bin/parity-routes.php --json",
    "parity:fields": "php bin/parity-check.php",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.11.0",
    "axios": "^1.11.0",
    "concurrently": "^9.0.1",
    "laravel-vite-plugin": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.0.7"
  },
  "dependencies": {
    "playwright": "^1.42.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "php": ">=8.2.0"
  }
}
