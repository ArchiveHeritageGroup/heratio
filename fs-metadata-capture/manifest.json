{
  "manifest_version": 3,
  "name": "FS Metadata Capture",
  "version": "3.0.0",
  "description": "Scrape FamilySearch metadata (single + multi-row), download full document images, export CSV.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.familysearch.org/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
