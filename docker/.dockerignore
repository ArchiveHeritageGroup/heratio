# / `npm ci` will produce inside the container.
.git
.github
node_modules
vendor
storage/logs/*.log
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/uploads
storage/backups
public/build
*.log
.env
.env.*
!.env.example
!docker/.env.docker.example
docker/.env.docker
.idea
.vscode
*.sql.gz
docs/papers
docs/images
docs/assets
