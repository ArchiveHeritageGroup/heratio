#!/bin/bash
#===============================================================================
# AtoM Heratio - Release Script
#===============================================================================
# Usage: ./bin/release patch|minor|major "commit message" [--issue N]
#
# Examples:
#   ./bin/release patch "Fix user browse GROUP_CONCAT"
#   ./bin/release minor "Phase 4: Admin & Settings" --issue 42
#   ./bin/release patch "Bug fixes" --issue 15,16,17
#===============================================================================
set -e

TYPE=${1:-patch}
MSG=${2:-"Bug fixes and improvements"}
ISSUE_ARG=""
INCLUDE_DRIFT=0

# Parse --issue argument
for arg in "$@"; do
    if [[ "$arg" == "--issue" ]]; then
        ISSUE_ARG="next"
    elif [[ "$ISSUE_ARG" == "next" ]]; then
        ISSUE_ARG="$arg"
    elif [[ "$arg" == "--include-drift" ]]; then
        INCLUDE_DRIFT=1
    fi
done

cd "$(dirname "$0")/.."
REPO="ArchiveHeritageGroup/heratio"

VERSION_FILE="version.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}════════════════════════════════════════════${NC}"
echo -e "${CYAN}  AtoM Heratio - Release${NC}"
echo -e "${CYAN}════════════════════════════════════════════${NC}"
echo ""

# Locked-paths gate. Refuses to release if any change touches a locked path
# that hasn't been explicitly unlocked. See bin/check-locked + .locked-paths.
if [ -x "./bin/check-locked" ]; then
    if ! ./bin/check-locked; then
        echo -e "${RED}Release aborted by lock manifest. See message above.${NC}"
        exit 1
    fi
fi

if [ ! -f "$VERSION_FILE" ]; then
    echo -e "${RED}Error: version.json not found${NC}"
    exit 1
fi

# Parse current version
CURRENT=$(php -r "\$j=json_decode(file_get_contents('${VERSION_FILE}'),true); echo \$j['version'] ?? '1.0.0';")

if [ -z "$CURRENT" ] || [ "$CURRENT" = "null" ]; then
    echo -e "${RED}Error: Could not parse version${NC}"
    exit 1
fi

echo -e "Current version: ${YELLOW}v${CURRENT}${NC}"

# Split version
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

# Calculate new version
case $TYPE in
    patch) PATCH=$((PATCH + 1)) ;;
    minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
    major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
    *) echo "Usage: ./bin/release patch|minor|major \"message\" [--issue N]"; exit 1 ;;
esac

NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"
DATE=$(date +%Y-%m-%d)
TAG="v${NEW_VERSION}"

echo -e "New version:     ${GREEN}${TAG}${NC}"
echo -e "Message:         ${MSG}"
[[ -n "$ISSUE_ARG" ]] && echo -e "Issues:          #${ISSUE_ARG}"
echo ""

# Update version.json
php -r "
\$j = json_decode(file_get_contents('${VERSION_FILE}'), true);
\$j['version'] = '${NEW_VERSION}';
\$j['release_date'] = '${DATE}';
file_put_contents('${VERSION_FILE}', json_encode(\$j, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . \"\n\");
"

#===============================================================================
# Git operations
#===============================================================================
echo -e "${BLUE}[1/3] Committing changes...${NC}"

# Build commit message with issue references
COMMIT_MSG="${TAG}: ${MSG}"
if [[ -n "$ISSUE_ARG" ]]; then
    FIXES=""
    IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
    for issue in "${ISSUES[@]}"; do
        issue=$(echo "$issue" | tr -d ' ')
        if [[ -n "$FIXES" ]]; then
            FIXES="$FIXES, Closes #$issue"
        else
            FIXES="Closes #$issue"
        fi
    done
    COMMIT_MSG="${TAG}: ${MSG}

${FIXES}"
fi

#===============================================================================
# Stage the release
#===============================================================================
# Staging happens BEFORE the session log is written, so the log reports what is
# actually committed. Previously the log ran `git diff --cached` ahead of
# `git add -A`, so it described only what the caller had pre-staged: v1.154.400
# logged 1 file while committing 5. An accurate list is the cheapest guard
# against this whole class of mistake.
#
# RELEASE_EXCLUDE holds paths that are permanently divergent in a working tree
# and must never ride along in an unrelated release. Pass --include-drift (or
# set RELEASE_EXCLUDE="") when a dependency change genuinely belongs here.
RELEASE_EXCLUDE=${RELEASE_EXCLUDE-"composer.json composer.lock"}
[[ "$INCLUDE_DRIFT" == "1" ]] && RELEASE_EXCLUDE=""

git add -A

EXCLUDED=""
for _p in $RELEASE_EXCLUDE; do
    if ! git diff --cached --quiet -- "$_p" 2>/dev/null; then
        git reset -q HEAD -- "$_p" 2>/dev/null || true
        EXCLUDED="${EXCLUDED} ${_p}"
    fi
done
if [[ -n "$EXCLUDED" ]]; then
    echo -e "${YELLOW}Held back from this release (drift):${NC}${EXCLUDED}"
    echo -e "${YELLOW}  left as uncommitted working-tree changes${NC}"
    echo -e "${YELLOW}  re-run with --include-drift if they belong in this commit${NC}"
    echo ""
fi

# version.json is rewritten above, so something is ALWAYS staged; the guard has
# to ask whether anything MEANINGFUL is staged. Without this, holding back drift
# turns a drift-only release into a content-free version bump. The bump is
# rolled back on abort so it cannot leak into the next release.
if [[ -z "$(git diff --cached --name-only | grep -vE '^version\.json$' || true)" ]]; then
    echo -e "${RED}Nothing to release: only version.json would change.${NC}"
    if [[ -n "$EXCLUDED" ]]; then
        echo -e "${YELLOW}  held back:${EXCLUDED}${NC}"
        echo -e "${YELLOW}  if that drift IS the release, re-run with --include-drift${NC}"
    fi
    git reset -q HEAD -- version.json 2>/dev/null || true
    git checkout -- version.json 2>/dev/null || true
    echo -e "${YELLOW}  version.json bump rolled back${NC}"
    exit 1
fi

echo -e "${BLUE}Staged for ${TAG}:${NC}"
git diff --cached --stat | tail -25
echo ""

# Auto-generate the per-release session log so docs/sessions/ is a complete
# audit timeline of every release. The KM indexer crawls this tree; until the
# central `/var/spool/km-ingest/` watched folder ships, this in-repo file is
# the canonical KM publish surface. See /root/.claude/CLAUDE.md "KM
# auto-publish rule". Written after staging so its file list is truthful, and
# staged itself below so it still lands in this release's commit.
SESSION_LOG_DIR="docs/sessions"
SESSION_LOG_FILE="${SESSION_LOG_DIR}/${DATE}-${TAG}.md"
mkdir -p "${SESSION_LOG_DIR}"
{
    echo "# ${TAG} (${DATE})"
    echo
    echo "${MSG}"
    echo
    if [[ -n "$ISSUE_ARG" ]]; then
        echo "## Closes"
        IFS=',' read -ra _ISSUES <<< "$ISSUE_ARG"
        for _issue in "${_ISSUES[@]}"; do
            _issue=$(echo "$_issue" | tr -d ' ')
            echo "- [#${_issue}](https://github.com/ArchiveHeritageGroup/heratio/issues/${_issue})"
        done
        echo
    fi
    echo "## Files in this release"
    echo
    echo '```'
    git diff --cached --stat | head -100
    if [[ -n "$EXCLUDED" ]]; then
        echo
        echo "Held back (drift, left uncommitted):${EXCLUDED}"
    fi
    echo '```'
    echo
    echo "## Release link"
    echo
    echo "https://github.com/ArchiveHeritageGroup/heratio/releases/tag/${TAG}"
} > "${SESSION_LOG_FILE}"

# Best-effort drop into the KM ingest spool when it exists. Never fail the
# release because the spool isn't there.
if [[ -d /var/spool/km-ingest ]]; then
    cp "${SESSION_LOG_FILE}" "/var/spool/km-ingest/heratio-${TAG}-$(date +%s).md" 2>/dev/null \
        || echo -e "${YELLOW}(KM spool drop skipped — permission)${NC}"
fi

git add -- "${SESSION_LOG_FILE}"
git commit -m "$COMMIT_MSG"

echo -e "${BLUE}[2/3] Creating tag ${TAG}...${NC}"
git tag -a "${TAG}" -m "${MSG}"

echo -e "${BLUE}[3/3] Pushing to origin...${NC}"
# Push the CURRENT branch tip straight to remote main (fast-forwards from any
# working branch). Using `HEAD:main` instead of `main` avoids the recurring
# non-fast-forward rejection caused by a stale local `main` ref, which (under
# `set -e`) also aborted the tag push + lock re-arm below.
git push origin HEAD:main
git push origin "${TAG}"

# One-shot unlocks expire here — successful push re-arms the lock. Future
# changes to locked paths require a fresh ./bin/unlock invocation.
if [ -f ".git/UNLOCKED" ]; then
    rm -f ".git/UNLOCKED"
    echo -e "${YELLOW}Cleared one-shot unlock list. Lock manifest is fully active again.${NC}"
fi

#===============================================================================
# GitHub Release
#===============================================================================
if command -v gh &> /dev/null && gh auth status &> /dev/null 2>&1; then
    echo ""
    echo -e "${BLUE}Creating GitHub release...${NC}"

    RELEASE_NOTES="## AtoM Heratio ${TAG}

**Release Date:** ${DATE}

### Changes
${MSG}"

    if [[ -n "$ISSUE_ARG" ]]; then
        RELEASE_NOTES="${RELEASE_NOTES}

### Related Issues"
        IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
        for issue in "${ISSUES[@]}"; do
            issue=$(echo "$issue" | tr -d ' ')
            RELEASE_NOTES="${RELEASE_NOTES}
- Closes #${issue}"
        done
    fi

    RELEASE_NOTES="${RELEASE_NOTES}

### Installation
\`\`\`bash
git clone https://github.com/ArchiveHeritageGroup/heratio.git
cd heratio && composer install
cp .env.example .env && php artisan key:generate
\`\`\`
"

    gh release create "${TAG}" \
        --repo "$REPO" \
        --title "AtoM Heratio ${TAG}" \
        --notes "${RELEASE_NOTES}" 2>/dev/null || echo "  Release may already exist"

    #===========================================================================
    # Update linked issues
    #===========================================================================
    if [[ -n "$ISSUE_ARG" ]]; then
        echo ""
        echo -e "${BLUE}Updating linked issues...${NC}"

        IFS=',' read -ra ISSUES <<< "$ISSUE_ARG"
        for issue in "${ISSUES[@]}"; do
            issue=$(echo "$issue" | tr -d ' ')
            echo "  Completing issue #$issue..."

            gh issue edit "$issue" --repo "$REPO" \
                --remove-label "status: in-progress" \
                --remove-label "status: parked" \
                --remove-label "status: future" 2>/dev/null || true

            gh issue close "$issue" --repo "$REPO" \
                --comment "Completed in ${TAG}

- Release: [${TAG}](https://github.com/ArchiveHeritageGroup/heratio/releases/tag/${TAG})
- Date: ${DATE}
- Changes: ${MSG}" 2>/dev/null || echo "    Warning: Could not close issue #$issue"
        done
    fi
fi

#===============================================================================
# Summary
#===============================================================================
echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}                      RELEASE COMPLETE                         ${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Version:  ${GREEN}${TAG}${NC}"
echo -e "  Date:     ${DATE}"
echo -e "  Message:  ${MSG}"
if [[ -n "$ISSUE_ARG" ]]; then
    echo -e "  Issues:   ${GREEN}#${ISSUE_ARG} (closed)${NC}"
fi
echo ""
echo -e "  ${CYAN}https://github.com/ArchiveHeritageGroup/heratio/releases/tag/${TAG}${NC}"
echo ""
