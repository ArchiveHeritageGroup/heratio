{
    "name": "ahg/biblio-bf",
    "description": "AHG BIBFRAME integration - serialises bibliographic records to/from BIBFRAME 2.0 RDF via the OpenRiC RiC-O service layer.",
    "type": "heratio-plugin",
    "license": "AGPL-3.0",
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "AhgBiblioBf\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AhgBiblioBf\\Providers\\AhgBiblioBfServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
