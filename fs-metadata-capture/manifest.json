{
  "manifest_version": 3,
  "name": "FS Metadata Capture",
  "version": "2.0.0",
  "description": "Scrape FamilySearch metadata, download full document images, export CSV.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.familysearch.org/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
